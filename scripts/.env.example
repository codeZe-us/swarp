# Deployer Account Secret Key
# The secret key of the account that will deploy the contracts and sign setup transactions.
# Format: S... (56 characters uppercase alphanumeric). NEVER commit the actual secret key.
DEPLOYER_SECRET_KEY=SAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Deployer Account Public Key (Address)
# The public address of the account deploying the contracts.
# Format: G... (56 characters uppercase alphanumeric).
DEPLOYER_PUBLIC_KEY=GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Stellar Horizon Server URL
# The Horizon API server endpoint for querying accounts, ledger status, and submit operations.
# For Testnet, use: https://horizon-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC Server URL
# The RPC server endpoint for contract deployments, invocation, and transaction status queries.
# For Testnet, use: https://soroban-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar Network Passphrase
# Used to verify signature integrity for the destination network.
# For Testnet, use: "Testnet Public Stellar Network ; September 2015"
STELLAR_NETWORK_PASSPHRASE="Testnet Public Stellar Network ; September 2015"

# Smart Contract Address
# If already deployed, specify the contract ID here to run updates or interactions.
# Format: C... (56 characters alphanumeric).
SWARP_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA1
